# Configurações do Sua Obra App

# Configurações da API do Gemini
# Obtenha sua chave em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here


WHATSMEOW_APIKEY=9F3C7A1E5B2D8C4F6A7E9D1B3C5F8A2D
WHATSMEOW_URL=https://wuzapi-server-production.up.railway.app/
WHATSMEOW_WEBHOOK_BASE=https://wuzapi-server-production.up.railway.app/

# Configurações do Serviço de Mensageria (para envio de emails/WhatsApp)
MESSENGER_TOKEN=your_messenger_service_token_here
MESSENGER_BASE_URL=https://your-messenger-service-url.com

# Configurações do Ambiente
ENV=development
DEBUG=LOW

# Discord para notificações (opcional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_url

# Exemplo de configuração completa:
# GEMINI_API_KEY=AIzaSyA1B2C3D4E5F6G7H8I9J0K1L2M3N4O5P6Q
# MESSENGER_TOKEN=abc123def456ghi789
# MESSENGER_BASE_URL=https://api.messenger-service.com
# ENV=production
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/123456789/abcdefgh